# ============================================================
# Abilix AI Marketing Studio - Environment Variables
# Copy to .env and fill in real values (never commit .env)
# ============================================================

# --- Server ---
PORT=3000
NODE_ENV=production
APP_NAME=Abilix AI Marketing Studio
APP_URL=https://your-domain.com
CLIENT_URL=https://your-domain.com

# --- JWT ---
JWT_SECRET=change_this_to_a_long_random_string
JWT_REFRESH_SECRET=change_this_to_another_long_random_string
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# --- Database (Hostinger MySQL) ---
DB_HOST=localhost
DB_PORT=3306
DB_NAME=abilix_marketing
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_CONNECTION_LIMIT=10

# --- AI Provider (provider-agnostic; OpenAI-compatible) ---
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
# Optional Anthropic support
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# --- Google OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://your-domain.com/api/auth/google/callback

# --- SMTP (email) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Abilix AI Marketing Studio <no-reply@your-domain.com>"

# --- Meta / WhatsApp (optional integrations) ---
META_APP_ID=
META_APP_SECRET=
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=

# --- Uploads / Security ---
UPLOAD_DIR=public/uploads
MAX_UPLOAD_MB=10
RATE_LIMIT_WINDOW_MIN=15
RATE_LIMIT_MAX=300
CORS_ORIGIN=https://your-domain.com
